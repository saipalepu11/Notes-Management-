<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login — Notes</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>

    :root {
      --ink:     #0f0e17;
      --paper:   #fffcf5;
      --accent:  #ff6b35;
      --muted:   #9a9180;
      --border:  #e8e0d0;
      --card:    #ffffff;
    }

    *, *::before, *::after {
      margin: 0; padding: 0; box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: var(--paper);
      display: flex;
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
    }

    /* ── LEFT PANEL ── */
    .left {
      width: 48%;
      background: var(--ink);
      padding: 60px 64px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }

    /* Decorative circles */
    .left::before {
      content: '';
      position: absolute;
      width: 480px; height: 480px;
      border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,0.06);
      top: -140px; left: -140px;
    }
    .left::after {
      content: '';
      position: absolute;
      width: 320px; height: 320px;
      border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,0.06);
      bottom: -80px; right: -80px;
    }

    .brand {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: #fff;
      letter-spacing: -0.5px;
      position: relative; z-index: 1;
    }
    .brand span { color: var(--accent); }

    .left-body {
      position: relative; z-index: 1;
    }

    .left-body h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(42px, 5vw, 64px);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -2px;
      margin-bottom: 24px;
    }

    .left-body h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .left-body p {
      color: var(--muted);
      font-size: 16px;
      line-height: 1.7;
      max-width: 340px;
    }

    .dots {
      display: flex; gap: 10px;
      position: relative; z-index: 1;
    }
    .dots span {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
    }
    .dots span:first-child { background: var(--accent); }

    /* ── RIGHT PANEL ── */
    .right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 40px;
      position: relative;
    }

    /* Subtle grid texture */
    .right::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.4;
    }

    .form-wrap {
      width: 100%;
      max-width: 400px;
      position: relative; z-index: 1;
      animation: rise 0.7s cubic-bezier(0.22,1,0.36,1) both;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(32px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .form-header {
      margin-bottom: 40px;
    }

    .form-header .eyebrow {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .form-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -1px;
      line-height: 1.15;
    }

    /* ── INPUTS ── */
    .field {
      margin-bottom: 22px;
    }

    .field label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .field input {
      width: 100%;
      padding: 14px 18px;
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .field input::placeholder { color: #c5bdb0; }

    .field input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(255,107,53,0.1);
    }

    /* ── BUTTON ── */
    .btn-login {
      width: 100%;
      padding: 15px;
      margin-top: 10px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      letter-spacing: 0.3px;
      position: relative;
      overflow: hidden;
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .btn-login::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--accent), #ff8c42);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(15,14,23,0.22);
    }
    .btn-login:hover::after { opacity: 1; }

    .btn-login span {
      position: relative; z-index: 1;
    }

    /* ── FOOTER ── */
    .form-footer {
      text-align: center;
      margin-top: 28px;
      font-size: 14px;
      color: var(--muted);
    }

    .form-footer a {
      color: var(--ink);
      font-weight: 500;
      text-decoration: none;
      border-bottom: 1.5px solid var(--accent);
      padding-bottom: 1px;
      transition: color 0.2s;
    }
    .form-footer a:hover { color: var(--accent); }

    /* ── DIVIDER ── */
    .divider {
      display: flex; align-items: center; gap: 14px;
      margin: 28px 0;
    }
    .divider hr { flex: 1; border: none; border-top: 1px solid var(--border); }
    .divider span { font-size: 12px; color: var(--muted); white-space: nowrap; }

    /* ── RESPONSIVE ── */
    @media (max-width: 720px) {
      .left { display: none; }
      .right { padding: 40px 24px; }
    }

  </style>
</head>
<body>

  <!-- LEFT -->
  <div class="left">
    <div class="brand">Notes<span>.</span></div>

    <div class="left-body">
      <h1>Your thoughts,<br><em>organized.</em></h1>
      <p>A calm space for your ideas, tasks, and everything in between. Pick up right where you left off.</p>
    </div>

    <div class="dots">
      <span></span><span></span><span></span>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="right">
    <div class="form-wrap">

      <div class="form-header">
        <p class="eyebrow">Welcome back</p>
        <h2>Sign in to<br>your account</h2>
      </div>

      <form action="/login" method="POST">

        <div class="field">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@example.com" required>
        </div>

        <div class="field">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
        </div>

        <button class="btn-login" type="submit">
          <span>Sign in →</span>
        </button>

      </form>

      <div class="divider">
        <hr><span>don't have an account?</span><hr>
      </div>

      <div class="form-footer">
        <a href="/register">Create one — it's free</a>
      </div>

    </div>
  </div>

</body>
</html>
