<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>



   




<div class="auth-container">
    <div class="auth-card">
        <h2>Create Account 🚀</h2>
        <p class="subtitle">Join us today</p>

        <form action="/register" method="POST">
            <div class="input-group">
                <label>Full Name</label>
                <input type="text"  name="name"required>
            </div>

            <div class="input-group">
                <label>Email</label>
                <input type="email" name="email"required>
            </div>

            <div class="input-group">
                <label>Password</label>
                <input type="password" name="password" required> 
            </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password" required>
            </div>

            <button class="btn">Register</button>

            <p class="switch">
                Already have an account?
                <a href="/">Login</a>
            </p>
        </form>
    </div>
</div>


</body>
</html>
<style>
    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Poppins", sans-serif;
}

body {
    height: 100vh;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-container {
    width: 100%;
    max-width: 420px;
    padding: 20px;
}

.auth-card {
    background: #fff;
    padding: 35px;
    border-radius: 15px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    animation: fadeIn 0.6s ease;
}

.auth-card h2 {
    text-align: center;
    margin-bottom: 8px;
    color: #333;
}

.subtitle {
    text-align: center;
    color: #777;
    margin-bottom: 30px;
}

.input-group {
    position: relative;
    margin-bottom: 25px;
}

.input-group input {
    width: 100%;
    padding: 12px 10px;
    border: none;
    border-bottom: 2px solid #ccc;
    outline: none;
    font-size: 16px;
}

.input-group label {
    position:static;
    left: 10px;
    top: 12px;
    color: #999;
    transition: 0.3s;
    pointer-events: none;
}

.input-group input:focus + label,
.input-group input:valid + label {
    top: -10px;
    font-size: 13px;
    color: #667eea;
}

.input-group input:focus {
    border-bottom-color: #667eea;
}

.btn {
    width: 100%;
    padding: 12px;
    border: none;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    font-size: 16px;
    border-radius: 30px;
    cursor: pointer;
    transition: 0.3s;
}

.btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(0,0,0,0.2);
}

.switch {
    text-align: center;
    margin-top: 20px;
    color: #555;
}

.switch a {
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.error {
    color: red;
    text-align: center;
    margin-bottom: 10px;
}

/* Success message */
.success {
    color: green;
    text-align: center;
    margin-bottom: 10px;
}
</style>